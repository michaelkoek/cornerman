# Firebase Web app config — Cornerman talks to Firestore + Auth directly from
# the browser. These values are PUBLIC client config (not secrets): copy them
# from the Firebase console → Project settings → Your apps → Web app → SDK setup
# and configuration → "Config". Access is protected by Firestore security rules
# and Firebase Auth, not by keeping these hidden.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Legacy (server/ only; not used by the static client) ---
# Strava is now synced by n8n, not the app. Kept for the legacy Node backend.
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
