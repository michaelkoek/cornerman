{
  "name": "cornerman",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c red,yellow \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "deploy:build": "vite build",
    "start": "tsx server/index.ts",
    "preview": "vite preview",
    "prep:library": "tsx scripts/prepare-exercise-library.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "better-sqlite3": "^12.11.1",
    "firebase": "^12.15.0",
    "hono": "^4.12.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "firebase-admin": "^14.2.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
